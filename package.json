{
  "name": "tijaratpro",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:electron": "tsup --watch --onSuccess \"electron dist-electron/main.js\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:electron\"",
    "build": "next build",
    "build:electron": "tsup",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "pack": "npm run build && npm run build:electron && electron-builder"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.18.0",
    "next": "15.5.19",
    "pdfjs-dist": "^6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.79.0",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.tijaratpro.desktop",
    "productName": "TijaratPro",
    "protocols": {
      "name": "TijaratPro",
      "schemes": [
        "tijaratpro"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tijaratpro",
        "repo": "desktop-app"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TijaratPro"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "knip": "^6.17.1",
    "tailwindcss": "^4",
    "ts-prune": "^0.10.3",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
